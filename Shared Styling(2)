.about {
  background: white;
  margin: 20px;
  padding: 30px;
  border-radius: 12px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.15);
  max-width: 900px;
  margin-left: auto;
  margin-right: auto;
}

.about h2, .about h3 {
  text-align: center;
  color: black;
}

.about p {
  line-height: 1.6;
  color: #333;
  margin-bottom: 15px;
}
